# ---- Database (matches docker-compose.yml) ----
DATABASE_URL=postgresql+psycopg://creator:creator@localhost:5433/creator_rag

# ---- LLM via OpenRouter ----
# One key, two tiers: a cheap open model for routing + a flagship for synthesis.
# Swap either model name to change providers without touching code (NFR-5).
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Cheap, fast, reliable at one-word intent classification. A smaller open model
# (e.g. meta-llama/llama-3.1-8b-instruct) is cheaper but misroutes more often.
ROUTER_MODEL=anthropic/claude-3.5-haiku
SYNTHESIS_MODEL=anthropic/claude-sonnet-4.6
# Cap synthesis output tokens (bounds cost; avoids OpenRouter credit pre-reservation).
SYNTHESIS_MAX_TOKENS=1024

# ---- Instagram metadata provider ----
# instaloader (free, local, demo-grade) | apify (managed, paid, production)
IG_PROVIDER=instaloader
# Required only when IG_PROVIDER=apify
APIFY_API_TOKEN=
# Optional: instaloader login session for follower counts / fewer rate limits
IG_USERNAME=

# ---- Embeddings (local, CPU) ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ---- Transcription (local faster-whisper) ----
WHISPER_MODEL=base

# ---- App ----
# Comma-separated origins allowed by CORS (Next.js dev server)
CORS_ORIGINS=http://localhost:3000
