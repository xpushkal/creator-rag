# ---- Database (matches docker-compose.yml) ----
DATABASE_URL=postgresql+psycopg://creator:creator@localhost:5433/creator_rag

# ---- LLM (any OpenAI-compatible provider) ----
# Swap base_url + key + model names to change providers — no code change (NFR-5).
#   Groq (free, fast):  https://api.groq.com/openai/v1        key: gsk_...
#   OpenRouter:         https://openrouter.ai/api/v1          key: sk-or-...
#   DeepSeek:           https://api.deepseek.com              key: sk-...
#   Gemini (compat):    https://generativelanguage.googleapis.com/v1beta/openai/
#   Ollama (local):     http://localhost:11434/v1             key: ollama
LLM_API_KEY=gsk_...
LLM_BASE_URL=https://api.groq.com/openai/v1
# Routing only needs a one-word answer; synthesis is where quality matters.
ROUTER_MODEL=llama-3.3-70b-versatile
SYNTHESIS_MODEL=llama-3.3-70b-versatile
# Cap synthesis output tokens (bounds cost; avoids provider quota pre-reservation).
SYNTHESIS_MAX_TOKENS=1024

# ---- Instagram metadata provider ----
# instaloader (free, local, demo-grade) | apify (managed, paid, production)
IG_PROVIDER=instaloader
# Required only when IG_PROVIDER=apify
APIFY_API_TOKEN=
# Optional: instaloader login session for follower counts / fewer rate limits
IG_USERNAME=

# ---- Embeddings (local, CPU) ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ---- YouTube ----
# If YouTube blocks anonymous access ("No video formats found" / empty
# transcripts), authenticate yt-dlp with a browser's cookies: set to
# chrome | safari | firefox | edge | brave. Empty = anonymous.
YT_COOKIES_FROM_BROWSER=

# ---- Transcription ----
# groq (hosted Whisper, ~1s, reuses the Groq LLM key) | local (faster-whisper, CPU)
TRANSCRIBE_PROVIDER=groq
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
WHISPER_MODEL=base

# ---- App ----
# Comma-separated origins allowed by CORS (Next.js dev server)
CORS_ORIGINS=http://localhost:3000
